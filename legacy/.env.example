# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=
STAGE=dev

# DynamoDB
DYNAMODB_TABLE_NAME=TowCommand-dev
DYNAMODB_ENDPOINT=http://localhost:4566

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-southeast-1

# EventBridge
EVENT_BUS_NAME=towcommand-dev

# S3
S3_EVIDENCE_BUCKET=towcommand-evidence-dev
S3_UPLOADS_BUCKET=towcommand-uploads-dev

# Payment (PayMongo)
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=

# AI (Bedrock)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=ap-southeast-1

# External APIs
GOOGLE_MAPS_API_KEY=
SEMAPHORE_API_KEY=

# WebSocket
WEBSOCKET_API_URL=ws://localhost:3001

